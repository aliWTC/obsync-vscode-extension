{
  "name": "obsync-vscode-extension",
  "displayName": "Obsync",
  "description": "Sync project code snapshots, versions, and optional function lineage into an Obsidian vault.",
  "version": "0.1.3",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codesync.syncFile",
        "title": "Obsync: Sync Current File"
      },
      {
        "command": "codesync.syncProject",
        "title": "Obsync: Sync Entire Project"
      },
      {
        "command": "codesync.setVaultPath",
        "title": "Obsync: Set Vault Path"
      },
      {
        "command": "codesync.changeVaultPath",
        "title": "Obsync: Change Vault Path"
      },
      {
        "command": "codesync.setSyncFunctions",
        "title": "Obsync: Toggle Function Sync"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesync",
          "title": "Obsync",
          "icon": "media/codesync.svg"
        }
      ]
    },
    "views": {
      "codesync": [
        {
          "id": "codesync.sidebar",
          "name": "Obsync",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codesync.syncProject",
          "when": "view == codesync.sidebar && codesync.hasWorkspace",
          "group": "navigation"
        },
        {
          "command": "codesync.syncFile",
          "when": "view == codesync.sidebar && codesync.hasWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "codesync.setVaultPath",
          "when": "view == codesync.sidebar && !codesync.hasVaultPath",
          "group": "navigation@2"
        },
        {
          "command": "codesync.changeVaultPath",
          "when": "view == codesync.sidebar && codesync.hasVaultPath",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Obsync",
      "properties": {
        "codesync.vaultPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to your Obsidian vault root (required before syncing)."
        },
        "codesync.ignoredExtensions": {
          "type": "array",
          "default": [
            ".json",
            ".lock",
            ".env",
            ".gitignore"
          ],
          "items": {
            "type": "string"
          },
          "description": "File extensions that Obsync should skip during project sync."
        },
        "codesync.ignoredFolders": {
          "type": "array",
          "default": [
            "node_modules",
            ".git",
            "dist",
            "build",
            ".next"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names that Obsync should skip during project sync."
        },
        "codesync.autoSyncOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync the current file on save (off by default)."
        },
        "codesync.syncFunctions": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, Obsync also generates per-function nodes and call-site links. Turning it off and running project sync removes only function nodes."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "lint": "tsc -p . --noEmit",
    "watch": "tsc -p . -w",
    "pretest": "npm run compile",
    "package:vsix": "npm run compile && vsce package",
    "package:vsix:allow-env": "npm run compile && vsce package --allow-package-env-file"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "2.24.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "dependencies": {
    "diff": "^8.0.2",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliWTC/obsync-vscode-extension.git"
  }
}
